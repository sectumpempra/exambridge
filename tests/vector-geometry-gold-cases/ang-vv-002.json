      "x": "1",
      "y": "1",
      "z": "0"
    }
  },
  "expectedStatus": "solved",
  "expectedResults": {
    "classification": "acute",
    "cosine": {
      "kind": "exact",
      "coefficient": "1/2",
      "radicand": "2"
    },
    "angleDegrees": 45
  },
  "tolerance": {
    "absolute": 1e-09,
    "relative": 1e-09
  },
  "independentDerivation": "手工推导：v1·v2 = 1；|v1| = 1，|v2| = √2；cos θ = 1/√2 = (1/2)√2；θ = 45°（acos 数值），acute。",
  "validationRules": [
    "cosine-within-bounds",
    "angle-range",
    "angle-classification"
  ]
