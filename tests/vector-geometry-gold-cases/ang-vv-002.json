{
  "caseId": "ang-vv-002",
  "category": "vector-angle",
  "description": "普通锐角：45°，余弦精确形 √2/2",
  "input": {
    "solver": "vectorAngle",
    "vector1": {
      "x": "1",
      "y": "0",
      "z": "0"
