{
  "caseId": "ang-vv-005",
  "category": "vector-angle",
  "description": "反向：两向量互为负倍数，夹角 180°，余弦精确为 −1",
  "input": {
    "solver": "vectorAngle",
    "vector1": {
      "x": "1",
      "y": "0",
      "z": "-2"
    },
    "vector2": {
      "x": "-2",
      "y": "0",
      "z": "4"
    }
  },
  "expectedStatus": "solved",
  "expectedResults": {
    "classification": "opposite-direction",
    "cosine": {
      "kind": "exact",
      "coefficient": "-1",
      "radicand": "1"
    },
    "angleDegrees": 180
  },
  "tolerance": {
    "absolute": 1e-09,
    "relative": 1e-09
  },
  "independentDerivation": "手工推导：v2 = −2·v1；v1·v2 = −2 − 8 = −10；|v1| = √5，|v2| = 2√5；cos θ = −10/10 = −1 → θ = 180°，opposite-direction。",
  "validationRules": [
    "cosine-within-bounds",
    "angle-range",
    "angle-classification",
    "parallel-cross-zero"
  ]
}
