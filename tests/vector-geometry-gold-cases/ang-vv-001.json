{
  "caseId": "ang-vv-001",
  "category": "vector-angle",
  "description": "垂直：点积为 0，夹角 90°，余弦精确为 0",
  "input": {
    "solver": "vectorAngle",
    "vector1": {
      "x": "1",
      "y": "2",
      "z": "3"
    },
    "vector2": {
      "x": "-2",
      "y": "1",
      "z": "0"
    }
  },
  "expectedStatus": "solved",
  "expectedResults": {
    "classification": "perpendicular",
    "cosine": {
      "kind": "exact",
      "coefficient": "0",
      "radicand": "1"
    },
    "angleDegrees": 90
  },
  "tolerance": {
    "absolute": 1e-09,
    "relative": 1e-09
  },
  "independentDerivation": "手工推导：v1·v2 = −2 + 2 + 0 = 0 → cos θ = 0 → θ = 90°，分类 perpendicular。应触发 perpendicular-dot-zero 残差验证。",
  "validationRules": [
    "cosine-within-bounds",
    "angle-range",
    "angle-classification",
    "perpendicular-dot-zero"
  ]
}
