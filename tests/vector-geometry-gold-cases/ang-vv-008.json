{
  "caseId": "ang-vv-008",
  "category": "vector-angle",
  "description": "几乎同向 + 容差路径：近似输入 5×10⁻¹⁰ 偏差判 same-direction，夹角 ≈ 0°",
  "input": {
    "solver": "vectorAngle",
    "vector1": {
      "x": {
        "input": "1",
        "approximation": "1"
      },
      "y": {
        "input": "0",
        "approximation": "0"
      },
      "z": {
        "input": "0",
        "approximation": "0"
      }
    },
    "vector2": {
      "x": {
        "input": "1",
        "approximation": "1"
      },
      "y": {
        "input": "0.0000000005",
        "approximation": "0.0000000005"
      },
      "z": {
        "input": "0",
        "approximation": "0"
      }
    }
  },
  "expectedStatus": "solved",
  "expectedResults": {
    "classification": "same-direction",
    "cosine": {
      "kind": "approximate",
      "value": 1
    },
    "angleDegrees": 0
  },
  "tolerance": {
    "absolute": 1e-09,
    "relative": 1e-09
