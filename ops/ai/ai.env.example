# Store the real file as /etc/exambridge/ai.env with mode 0600.
# Never place real values in the repository or web root.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://provider.example/v1
DEEPSEEK_MODEL=replace-with-configured-model-id
AI_PROVIDER_TIMEOUT_MS=60000
AI_ALLOWED_ORIGINS=https://exambridge.cn
