# Store the real file as /etc/exambridge/ai.env with mode 0600.
# Never place real values in the repository or web root.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://provider.example/v1
DEEPSEEK_MODEL=deepseek-v4-pro
AI_PROVIDER_TIMEOUT_MS=60000
AI_ALLOWED_ORIGINS=https://exambridge.cn
# Pro-only policy: simple questions use reasoning_effort=low; comparisons and explanations use max.
AI_DAILY_REQUEST_LIMIT=1000
AI_DAILY_TOKEN_LIMIT=20000000
AI_PROVIDER_FAILURE_THRESHOLD=5
AI_PROVIDER_COOLDOWN_MS=300000
